# Variables d'environnement - Production
# Copier ce fichier en .env.production et remplir les valeurs

# Base de données
DATABASE_URL="mysql://user:password@host:3306/riwaya_prod"

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# Olivraison API
OLIVRAISON_API_KEY=
OLIVRAISON_SECRET_KEY=
OLIVRAISON_WEBHOOK_SECRET=

# Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@riwaya.com

# Sécurité (générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=
SESSION_SECRET=

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
