# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env
.env*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/migrations

/src/generated/prisma

# Agent specific
brain/
scratch/
.gemini/
.agent/

# Backups and temporary files
*.sql
*.tar
*.zip
*.gz
/backups/
/public/uploads/backup_*

# Public uploads (except placeholders)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/book-placeholder.png

# Standalone build artifacts
server.js
/scripts/bundle-standalone.js
