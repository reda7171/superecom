generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemType {
  BOOK
  PACK
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ============================================
// MODELS
// ============================================

// Admin User
model CategoryConfig {
  id             String    @id @default(uuid())
  name           String    @unique
  badge          String?   // PROMO | NEW | HOT | etc.
  badgeColor     String?   // hex code or tailwind class
  badgeExpiresAt DateTime? // Date d'expiration pour le badge
  quote          String?   @db.Text
  quoteSource    String?   // L'auteur ou le livre
  isPinned       Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  category  String?
  createdAt DateTime @default(now())
}

model BadgeClick {
  id        String   @id @default(uuid())
  badge     String   // PROMO, NEW, HOTEL, etc.
  category  String
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashé avec bcrypt
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Exchange Profile (Community)
  fullName  String?  @db.VarChar(255)
  city      String?  @db.VarChar(100)
  credits   Int      @default(10) // Monnaie d'échange
  rating    Float    @default(5.0)
  image     String?  @db.VarChar(500)
  bio       String?  @db.Text
  instagram String?  @db.VarChar(100)
  facebook  String?  @db.VarChar(100)
  twitter   String?  @db.VarChar(100)

  // Relations
  ownedBooks        ExchangeBook[] @relation("OwnedBooks")
  sentExchanges     Exchange[]     @relation("SentExchanges")
  receivedExchanges Exchange[]     @relation("ReceivedExchanges")
  messages          Message[]
  notifications     Notification[]
  ratingsGiven      Rating[]       @relation("RatingsGiven")
  ratingsReceived   Rating[]       @relation("RatingsReceived")

  @@map("users")
}

// Livre
model Book {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  author      String      @db.VarChar(255)
  description String      @db.Text
  isbn        String?     @unique @db.VarChar(20)
  price         Float       @db.Double
  originalPrice Float?      @db.Double
  stock         Int         @default(0)
  image         String      @db.VarChar(500)
  category    String?     @db.VarChar(100)
  language    String      @default("fr") @db.VarChar(10)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  packBooks  PackBook[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([category])
  @@index([active])
  @@map("books")
}

// Pack de livres (Offre groupée)
model Pack {
  id          String      @id @default(uuid())
  name        String      @db.VarChar(255)
  description String?     @db.Text
  price       Float       @db.Double
  image       String?     @db.VarChar(500)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  books      PackBook[]
  orderItems OrderItem[]

  @@index([active])
  @@map("packs")
}

// Table de liaison Pack <-> Book (Many-to-Many)
model PackBook {
  id     String @id @default(uuid())
  packId String
  bookId String
  
  // Relations
  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([packId, bookId])
  @@index([packId])
  @@index([bookId])
  @@map("pack_books")
}

// Commande (COD - Cash On Delivery)
model Order {
  id        String      @id @default(uuid())
  
  // Informations client
  fullName  String      @db.VarChar(255)
  email     String?     @db.VarChar(255) // Optional pour compatibilité, mais requis par le front
  phone     String      @db.VarChar(20)
  address   String      @db.VarChar(500)
  city      String      @db.VarChar(100)
  comment   String?     @db.Text
  
  // Informations commande
  total     Float       @db.Double
  discount  Float       @default(0) @db.Double
  couponCode String?    @db.VarChar(50)
  status    OrderStatus @default(PENDING)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  // Relations
  items OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([phone])
  @@map("orders")
}

// Ligne de commande (peut être un livre ou un pack)
model OrderItem {
  id       String        @id @default(uuid())
  orderId  String
  type     OrderItemType // BOOK ou PACK
  quantity Int           @default(1)
  price    Float         @db.Double // Prix au moment de l'achat
  
  // Relations optionnelles (un seul des deux sera rempli selon le type)
  bookId String?
  packId String?
  
  // Relations
  order Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book?  @relation(fields: [bookId], references: [id], onDelete: SetNull)
  pack  Pack?  @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([bookId])
  @@index([packId])
  @@map("order_items")
}

// Code Promo
model Coupon {
  id          String     @id @default(uuid())
  code        String     @unique @db.VarChar(50)
  discount    Float      @db.Double // Valeur numérique
  type        CouponType @default(PERCENTAGE)
  minAmount   Float?     @db.Double
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("coupons")
}

// Avis Clients
model Review {
  id        String   @id @default(uuid())
  bookId    String
  fullName  String   @db.VarChar(255)
  rating    Int      @default(5)
  comment   String   @db.Text
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  // Relations
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([isApproved])
  @@map("reviews")
}

// ============================================
// EXCHANGE SYSTEM (V2)
// ============================================

enum ExchangeType {
  DIRECT
  CREDIT
  GIVEAWAY
}

enum ExchangeStatus {
  PENDING         // En attente
  ACCEPTED        // Accepté par le vendeur (en attente de livraison)
  REJECTED        // Refusé
  COUNTER_OFFER   // Contre-proposition (future)
  IN_PROGRESS     // Livraison en cours / RDV fixé
  COMPLETED       // Terminé (livres échangés)
  CANCELLED       // Annulé
}

enum BookCondition {
  NEW     // Comme neuf
  GOOD    // Bon état
  USED    // Occasion (traces d'usure)
}

// Livre dédié à l'échange (séparé du catalogue de vente)
model ExchangeBook {
  id          String        @id @default(uuid())
  ownerId     String
  
  title       String
  author      String
  isbn        String?
  condition   BookCondition @default(GOOD)
  description String?       @db.Text
  image       String?
  language    String        @default("fr")
  
  // Préférences d'échange
  exchangeType ExchangeType @default(DIRECT) // Ce que le propriétaire accepte
  
  status      String        @default("AVAILABLE") // AVAILABLE, PENDING, EXCHANGED
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  owner       User          @relation("OwnedBooks", fields: [ownerId], references: [id], onDelete: Cascade)
  offeredIn   Exchange[]    @relation("BookOffered")
  requestedIn Exchange[]    @relation("BookRequested")

  @@index([ownerId])
  @@index([status])
  @@map("exchange_books")
}

// Transaction d'échange
model Exchange {
  id              String         @id @default(uuid())
  
  requesterId     String
  responderId     String
  
  bookOfferedId   String?        // Null si échange contre crédits
  bookRequestedId String
  
  type            ExchangeType   @default(DIRECT)
  status          ExchangeStatus @default(PENDING)
  
  creditsAmount   Int?           // Montant crédits si applicable
  message         String?        @db.Text // Message initial
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  requester       User           @relation("SentExchanges", fields: [requesterId], references: [id])
  responder       User           @relation("ReceivedExchanges", fields: [responderId], references: [id])
  
  bookOffered     ExchangeBook?  @relation("BookOffered", fields: [bookOfferedId], references: [id])
  bookRequested   ExchangeBook   @relation("BookRequested", fields: [bookRequestedId], references: [id])
  chat            Chat?

  @@index([requesterId])
  @@index([responderId])
  @@index([status])
  @@map("exchanges")
}

// Chat entre utilisateurs pour un échange
model Chat {
  id         String    @id @default(uuid())
  exchangeId String    @unique
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  // Relations
  exchange   Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  messages   Message[]
  
  @@map("chats")
}

// Messages dans un chat
model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  // Relations
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])
  
  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

// Notifications utilisateur
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  link      String?          @db.VarChar(500)
  read      Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  
  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// Évaluations après échange
model Rating {
  id         String   @id @default(uuid())
  exchangeId String   @unique
  fromUserId String
  toUserId   String
  rating     Int      // 1-5
  comment    String?  @db.Text
  
  createdAt  DateTime @default(now())
  
  // Relations
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])
  
  @@index([fromUserId])
  @@index([toUserId])
  @@map("ratings")
}

enum NotificationType {
  EXCHANGE_REQUEST
  EXCHANGE_ACCEPTED
  EXCHANGE_REJECTED
  NEW_MESSAGE
  EXCHANGE_COMPLETED
  RATING_RECEIVED
}
