generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CategoryConfig {
  id             String    @id @default(uuid())
  name           String    @unique
  badge          String?
  badgeColor     String?
  badgeExpiresAt DateTime?
  quote          String?   @db.Text
  quoteSource    String?
  isPinned       Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  category  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

model BadgeClick {
  id        String   @id @default(uuid())
  badge     String
  category  String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String?  @db.Text
  category    String   @default("general")
  description String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("site_settings")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  role              UserRole       @default(ADMIN)
  isBanned          Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  fullName          String?        @db.VarChar(255)
  locale            String         @default("fr") @db.VarChar(5)
  city              String?        @db.VarChar(100)
  address           String?        @db.VarChar(500)
  neighborhood      String?        @db.VarChar(100)
  credits           Int            @default(10)
  rating            Float          @default(5)
  image             String?        @db.VarChar(500)
  bio               String?        @db.Text
  instagram         String?        @db.VarChar(100)
  facebook          String?        @db.VarChar(100)
  twitter           String?        @db.VarChar(100)
  phone             String?        @db.VarChar(20)
  ownedBooks        ExchangeBook[] @relation("OwnedBooks")
  sentExchanges     Exchange[]     @relation("SentExchanges")
  receivedExchanges Exchange[]     @relation("ReceivedExchanges")
  messages          Message[]
  notifications     Notification[]
  posts             Post[]
  ratingsGiven      Rating[]       @relation("RatingsGiven")
  ratingsReceived   Rating[]       @relation("RatingsReceived")
  readingList       ReadingList[]
  reportsGiven      Report[]       @relation("ReportsGiven")
  reportsReceived   Report[]       @relation("ReportsReceived")
  wishlist          Wishlist[]
  expenses          Expense[]
  pageViews         PageView[]
  coupons           Coupon[]       @relation("AffiliateCoupons")
  comments          Comment[]
  loginHistory      LoginHistory[]

  // Marketplace relations
  sellerBooks      Book[]      @relation("SellerBooks")
  sellerOrders     Order[]     @relation("SellerOrders")
  sellerOrderItems OrderItem[] @relation("SellerOrderItems")

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ip        String?
  userAgent String?  @db.LongText
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}


model Book {
  id              String        @id @default(uuid())
  title           String        @db.VarChar(255)
  author          String        @db.VarChar(255)
  description     String        @db.Text
  longDescription String?       @db.LongText
  bestQuote       String?       @db.Text
  bestLessons     String?       @db.Text
  bestFor         String?       @db.Text
  bestChapters    String?       @db.Text
  isbn            String?       @unique @db.VarChar(20)
  price           Float
  originalPrice   Float?
  costPrice       Float         @default(0) // Prix de revient unitaire (calculé via lots ou manuel)
  stock           Int           @default(0)
  image           String        @db.LongText
  previewUrl      String?       @db.LongText
  category        String?       @db.VarChar(100)
  language        String        @default("fr") @db.VarChar(10)
  active          Boolean       @default(true)
  status          String        @default("APPROVED") // PENDING, APPROVED, REJECTED
  isBestSeller    Boolean       @default(false)
  imageAlt        String?       @db.VarChar(500) // Alt text SEO pour l'image
  imageTitle      String?       @db.VarChar(500) // Title SEO pour l'image
  displayOrder    Int           @default(0)
  isOriginal      Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderItems      OrderItem[]
  packBooks       PackBook[]
  readingLists    ReadingList[]
  reviews         Review[]
  wishlists       Wishlist[]
  posts           Post[]        @relation("PostBooks")

  // Marketplace fields
  sellerId String?
  seller   User?   @relation("SellerBooks", fields: [sellerId], references: [id])

  @@index([category])
  @@index([active])
  @@index([active, stock])
  @@index([category, active])
  @@index([price, active])
  @@index([createdAt])
  @@index([language])
  @@map("books")
}

model Pack {
  id             String      @id @default(uuid())
  name           String      @db.VarChar(255)
  description    String?     @db.Text
  price          Float
  costPrice      Float       @default(0) // Prix de revient du pack entier
  image          String?     @db.VarChar(500)
  isFreeDelivery Boolean     @default(false)
  shippingFees   Float       @default(0)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
  books          PackBook[]
  wishlists      Wishlist[]

  @@index([active])
  @@map("packs")
}

model PackBook {
  id     String @id @default(uuid())
  packId String
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pack   Pack   @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([packId, bookId])
  @@index([packId])
  @@index([bookId])
  @@map("pack_books")
}

model Order {
  id             String               @id @default(uuid())
  fullName       String               @db.VarChar(255)
  email          String?              @db.VarChar(255)
  phone          String               @db.VarChar(20)
  address        String               @db.VarChar(500)
  city           String               @db.VarChar(100)
  comment        String?              @db.Text
  total          Float
  subtotal       Float?
  shippingFees   Float                @default(0)
  discount       Float                @default(0)
  couponCode     String?              @db.VarChar(50)
  status         OrderStatus          @default(PENDING)
  paymentMethod  String               @default("COD") @db.VarChar(50)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deliveryLabel  String?              @db.Text
  deliveryStatus String?              @db.VarChar(100)
  deliverySyncAt DateTime?
  trackingID     String?              @db.VarChar(100)
  deliveryNotes  String?              @db.Text
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]

  // Marketplace fields
  sellerId String?
  seller   User?   @relation("SellerOrders", fields: [sellerId], references: [id])

  // Customer link
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@index([status, createdAt])
  @@index([trackingID])
  @@index([customerId])
  @@map("orders")
}

model Customer {
  id            String   @id @default(uuid())
  fullName      String   @db.VarChar(255)
  email         String?  @db.VarChar(255)
  phone         String   @unique @db.VarChar(20)
  address       String?  @db.VarChar(500)
  city          String?  @db.VarChar(100)
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  lastOrderDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  comment   String?  @db.Text
  createdBy String   @default("SYSTEM")
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model OrderItem {
  id               String          @id @default(uuid())
  orderId          String
  type             OrderItemType
  quantity         Int             @default(1)
  price            Float // Prix de vente au moment de la commande
  costPrice        Float           @default(0) // Prix de revient au moment de la commande
  bookId           String?
  packId           String?
  giftId           String?
  digitalProductId String?
  book             Book?           @relation(fields: [bookId], references: [id])
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pack             Pack?           @relation(fields: [packId], references: [id])
  gift             Gift?           @relation(fields: [giftId], references: [id])
  digitalProduct   DigitalProduct? @relation("DigitalOrderItems", fields: [digitalProductId], references: [id])
  extraProductId   String?
  extraProduct     ExtraProduct?   @relation(fields: [extraProductId], references: [id])

  // Marketplace fields
  sellerId String?
  seller   User?   @relation("SellerOrderItems", fields: [sellerId], references: [id])

  @@index([orderId])
  @@index([bookId])
  @@index([packId])
  @@index([giftId])
  @@index([extraProductId])
  @@index([bookId, type])
  @@index([packId, type])
  @@index([giftId, type])
  @@map("order_items")
}

model Coupon {
  id        String     @id @default(uuid())
  code      String     @unique @db.VarChar(50)
  discount  Float
  type      CouponType @default(PERCENTAGE)
  minAmount Float?
  isActive  Boolean    @default(true)
  expiresAt DateTime?

  // Affiliate fields
  isAffiliate   Boolean @default(false)
  affiliateName String? @db.VarChar(255)
  commission    Float?  @default(0)
  userId        String?
  user          User?   @relation("AffiliateCoupons", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

model Review {
  id         String   @id @default(uuid())
  bookId     String
  fullName   String   @db.VarChar(255)
  city       String?  @db.VarChar(100)
  image      String?  @db.VarChar(500)
  rating     Int      @default(5)
  comment    String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([isApproved])
  @@map("reviews")
}

model ExchangeBook {
  id           String        @id @default(uuid())
  ownerId      String
  title        String
  author       String
  isbn         String?
  condition    BookCondition @default(GOOD)
  description  String?       @db.Text
  image        String?       @db.LongText
  language     String        @default("fr")
  exchangeType ExchangeType  @default(DIRECT)
  status       String        @default("AVAILABLE")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("OwnedBooks", fields: [ownerId], references: [id], onDelete: Cascade)
  offeredIn    Exchange[]    @relation("BookOffered")
  requestedIn  Exchange[]    @relation("BookRequested")
  reports      Report[]

  @@index([ownerId])
  @@index([status])
  @@index([status, createdAt])
  @@index([exchangeType])
  @@map("exchange_books")
}

model Exchange {
  id              String         @id @default(uuid())
  requesterId     String
  responderId     String
  bookOfferedId   String?
  bookRequestedId String
  type            ExchangeType   @default(DIRECT)
  status          ExchangeStatus @default(PENDING)
  creditsAmount   Int?
  message         String?        @db.Text
  deliveryMethod  String?
  meetingPoint    String?        @db.VarChar(255)
  meetingDate     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  chat            Chat?
  bookOffered     ExchangeBook?  @relation("BookOffered", fields: [bookOfferedId], references: [id])
  bookRequested   ExchangeBook   @relation("BookRequested", fields: [bookRequestedId], references: [id])
  requester       User           @relation("SentExchanges", fields: [requesterId], references: [id])
  responder       User           @relation("ReceivedExchanges", fields: [responderId], references: [id])
  rating          Rating?

  @@index([requesterId])
  @@index([responderId])
  @@index([status])
  @@index([status, createdAt])
  @@index([bookOfferedId], map: "exchanges_bookOfferedId_fkey")
  @@index([bookRequestedId], map: "exchanges_bookRequestedId_fkey")
  @@map("exchanges")
}

model Chat {
  id         String    @id @default(uuid())
  exchangeId String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  exchange   Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  link      String?          @db.VarChar(500)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

model Rating {
  id         String   @id @default(uuid())
  exchangeId String   @unique
  fromUserId String
  toUserId   String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  exchange   Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])

  @@index([exchangeId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("ratings")
}

model Report {
  id           String        @id @default(uuid())
  reason       String
  details      String?       @db.Text
  status       String        @default("PENDING")
  reporterId   String
  targetUserId String?
  targetBookId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reporter     User          @relation("ReportsGiven", fields: [reporterId], references: [id])
  targetBook   ExchangeBook? @relation(fields: [targetBookId], references: [id])
  targetUser   User?         @relation("ReportsReceived", fields: [targetUserId], references: [id])

  @@index([reporterId])
  @@index([targetUserId])
  @@index([targetBookId])
  @@index([status])
  @@map("reports")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  bookId    String?
  packId    String?
  title     String
  author    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book?    @relation(fields: [bookId], references: [id])
  pack      Pack?    @relation(fields: [packId], references: [id])

  @@index([userId])
  @@index([bookId])
  @@index([packId])
  @@map("wishlists")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
  @@index([entity])
  @@map("audit_logs")
}

model Menu {
  id        String     @id @default(uuid())
  slug      String     @unique
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isActive  Boolean    @default(true)
  items     MenuItem[]

  @@map("menus")
}

model MenuItem {
  id        String     @id @default(uuid())
  menuId    String
  parentId  String?
  label     String
  url       String
  order     Int        @default(0)
  target    String?
  icon      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuHierarchy")

  @@index([menuId])
  @@index([parentId])
  @@map("menu_items")
}

model ReadingList {
  id          String        @id @default(uuid())
  userId      String
  bookId      String?
  title       String
  author      String
  cover       String?       @db.LongText
  totalPages  Int           @default(0)
  currentPage Int           @default(0)
  status      ReadingStatus @default(TO_READ)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  book        Book?         @relation(fields: [bookId], references: [id])
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([bookId], map: "reading_list_bookId_fkey")
  @@map("reading_list")
}

model Post {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  content     String    @db.LongText
  coverImage  String?       @db.LongText
  authorId    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])
  viewCount   Int       @default(0)
  category    String?   @db.VarChar(100)
  tags        String?   @db.Text
  language    String    @default("fr") @db.VarChar(10)
  comments    Comment[]
  books       Book[]    @relation("PostBooks")

  @@index([slug])
  @@index([published])
  @@index([language])
  @@index([authorId], map: "posts_authorId_fkey")
  @@map("posts")
}

model Comment {
  id         String   @id @default(uuid())
  content    String   @db.Text
  postId     String
  userId     String?
  authorName String?  @db.VarChar(255)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

enum UserRole {
  ADMIN
  MANAGER
  INFLUENCER
  SELLER
  USER
  TEST
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum OrderItemType {
  BOOK
  PACK
  GIFT
  DIGITAL
  ACCESSORY
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ExchangeType {
  DIRECT
  CREDIT
  GIVEAWAY
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTER_OFFER
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookCondition {
  NEW
  GOOD
  USED
}

enum NotificationType {
  EXCHANGE_REQUEST
  EXCHANGE_ACCEPTED
  EXCHANGE_REJECTED
  NEW_MESSAGE
  EXCHANGE_COMPLETED
  RATING_RECEIVED
}

enum ReadingStatus {
  TO_READ
  READING
  COMPLETED
  ON_HOLD
  DROPPED
}

model Expense {
  id          String          @id @default(uuid())
  title       String          @db.VarChar(255)
  amount      Float
  category    ExpenseCategory
  date        DateTime        @default(now())
  description String?         @db.Text
  unitCost    Float? // Pour le prix de revient moyen d'un livre lors d'un achat en lot
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([date])
  @@map("expenses")
}

enum ExpenseCategory {
  TRANSPORT
  ADS
  MARKETING
  BOOKS_PURCHASE
  PACKAGING
  SALARIES
  OFFICE
  OTHER
  GIFTS
  CASHOUT
}

model PageView {
  id        String   @id @default(uuid())
  url       String
  ip        String?
  userAgent String?  @db.LongText
  sessionId String? // Cookie or session ID
  userId    String?
  country   String?
  city      String?
  device    String?
  referrer  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([sessionId])
  @@map("page_views")
}

model Advertisement {
  id         String      @id @default(uuid())
  title      String      @db.VarChar(255)
  image      String      @db.VarChar(500)
  link       String?     @db.VarChar(500)
  placement  AdPlacement
  isActive   Boolean     @default(false)
  priority   Int         @default(0)
  startDate  DateTime?
  endDate    DateTime?
  clickCount Int         @default(0)
  viewCount  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([placement, isActive])
  @@index([isActive, priority])
  @@map("advertisements")
}

enum AdPlacement {
  HOMEPAGE_TOP
  HOMEPAGE_MIDDLE
  HOMEPAGE_BOTTOM
  SIDEBAR
  BETWEEN_PRODUCTS
  BOOK_PAGE
  CHECKOUT
  FOOTER
}

model AuthorProfile {
  id          String  @id @default(uuid())
  name        String  @unique
  bio         String? @db.Text
  image       String? @db.VarChar(500)
  nationality String?
  birthYear   Int?
  deathYear   Int?
  influences  String? @db.Text // JSON string or comma separated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("author_profiles")
}

model AbandonedCart {
  id        String   @id @default(uuid())
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(255)
  fullName  String?  @db.VarChar(255)
  cartData  String   @db.Text
  total     Float
  status    String   @default("PENDING") // PENDING, RECOVERED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("abandoned_carts")
}

model Gift {
  id          String      @id @default(uuid())
  name        String      @db.VarChar(255)
  description String?     @db.Text
  price       Float       @default(0)
  costPrice   Float       @default(0)
  minAmount   Float       @default(0)
  image       String?     @db.VarChar(500)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@index([active])
}

// Produits numériques (livres PDF)
model DigitalProduct {
  id             String             @id @default(uuid())
  title          String             @db.VarChar(255)
  author         String             @db.VarChar(255)
  description    String             @db.Text
  price          Float
  originalPrice  Float?
  image          String             @db.VarChar(500)
  pdfUrl         String             @db.VarChar(500)
  category       String?            @db.VarChar(100)
  language       String             @default("fr") @db.VarChar(10)
  pages          Int?
  fileSize       String?            @db.VarChar(50)
  active         Boolean            @default(true)
  featured       Boolean            @default(false)
  downloadCount  Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  orderItems     DigitalOrderItem[]
  mainOrderItems OrderItem[]        @relation("DigitalOrderItems")

  @@index([active])
  @@index([category])
  @@index([featured])
  @@map("digital_products")
}

// Commandes produits numériques
model DigitalOrder {
  id           String             @id @default(uuid())
  fullName     String             @db.VarChar(255)
  email        String             @db.VarChar(255)
  phone        String             @db.VarChar(20)
  total        Float
  status       String             @default("PENDING")
  paymentProof String?            @db.VarChar(500)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        DigitalOrderItem[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("digital_orders")
}

model DigitalOrderItem {
  id               String         @id @default(uuid())
  orderId          String
  digitalProductId String
  quantity         Int            @default(1)
  price            Float
  downloadSent     Boolean        @default(false)
  order            DigitalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          DigitalProduct @relation(fields: [digitalProductId], references: [id])

  @@index([orderId])
  @@index([digitalProductId])
  @@map("digital_order_items")
}

model SellerRequest {
  id          String   @id @default(uuid())
  storeName   String   @db.VarChar(255)
  managerName String   @db.VarChar(255)
  email       String   @db.VarChar(255)
  phone       String   @db.VarChar(50)
  city        String   @db.VarChar(100)
  stockSize   String   @db.VarChar(50)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("seller_requests")
}
model ExtraProduct {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Float
  costPrice   Float    @default(0)
  stock       Int      @default(0)
  image       String?  @db.VarChar(500)
  category    String   @default("ACCESSORY") // BOOKMARK, FURNITURE, USB, etc.
  materials   String?  @db.VarChar(255)
  dimensions  String?  @db.VarChar(255)
  weight      String?  @db.VarChar(255)
  warranty    String?  @db.VarChar(255)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([category])
  @@index([active])
  @@map("extra_products")
}

model MarketingAsset {
  id        String   @id @default(uuid())
  name      String   @unique
  url       String
  type      String   // CREATIVE, PACK, DESCRIPTION
  bookId    String?
  packId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketing_assets")
}
